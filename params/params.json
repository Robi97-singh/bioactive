                        "final_div_factor": 0.01
                    },
                    "MultiStepLR": {
                        "milestones": [
                            10,
                            15
                        ],
                        "gamma": 0.1
                    },
                    "CosineAnnealingLR": {
                        "eta_min": 1e-05
                    },
                    "LinearWarmup": {
                        "warmup_epochs": 0,
                        "warmup_iters": 0
                    }
                }
            }
        }
    },
